# Copia este archivo a .env y rellena los valores

# Obligatorio en producción: clave secreta para firmar JWTs (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_una_clave_segura_aleatoria

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor (sobreescribe config/default.json)
PORT=3000

# Driver de base de datos: sqlite | mdb-hybrid
# mdb-hybrid: guarda en SQLite Y escribe en el MDB de Access
DB_DRIVER=sqlite

# Solo necesario con DB_DRIVER=mdb-hybrid
# Ruta absoluta al directorio donde el software de impresión leerá las fotos
# Ejemplo: C:\IDCard\fotos  o  \\servidor\fotos
PHOTOS_ABSOLUTE_BASE_PATH=

# Orígenes CORS permitidos separados por coma (útil para Cloudflare Tunnel)
# CORS_ORIGINS=https://mi-tunel.trycloudflare.com,http://192.168.1.100:3000

# Clave secreta para generar/validar códigos de activación de licencia.
# DEBE ser la misma clave que usas en tools/generate-license.js.
# Usa una cadena aleatoria larga (mínimo 32 caracteres).
LICENSE_SECRET=cambia-esto-por-una-clave-secreta-aleatoria
